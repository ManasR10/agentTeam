# Anthropic
ANTHROPIC_API_KEY=
# Default model
LLM_MODEL=claude-sonnet-4-6
# Response configuration
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=60
# Agent/tool loop configuration
TOOL_MAX_ITERATIONS=5
TOOL_WORKSPACE_ROOT=.
MAX_FILE_READ_CHARS=20000
# Phase 3 mutation limits
MAX_FILES_CHANGED=10
MAX_FILE_WRITE_CHARS=100000
MAX_TOTAL_WRITE_CHARS=300000
ALLOW_FILE_CREATION=true
ALLOW_FILE_OVERWRITE=true
# Phase 3 command execution limits
COMMAND_TIMEOUT_SECONDS=120
MAX_COMMAND_OUTPUT_CHARS=30000
